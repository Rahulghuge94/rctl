# Required
# The tunnel URL from the running server (set after server starts)
PUBLIC_URL="https://your-tunnel-url.trycloudflare.com"

# Auth
# Style A — Single project (legacy, simple)
AUTH_TOKEN="your-secret-token"
PROJECT_NAME="my_project"

# Optional
# Cloudflare zero-trust tunnel token (skip to use quick tunnels)
# CL_TUNNEL_TOKEN="your-cf-tunnel-token"